# ==========================================================
# SecureVu — Environment Configuration Template
# ==========================================================
# Copy this file to .env and fill in your actual credentials.
# NEVER commit the real .env file to Git.

# --- PostgreSQL Database ---
DB_USER=cctv_user
DB_PASS=REPLACE_WITH_YOUR_DB_PASSWORD
DB_NAME=cctv_platform
DB_HOST=127.0.0.1
# Local dev on Mac if port 5432 is taken by another Postgres: use 5434 (docker-compose maps 5434:5432)
DB_PORT=5434

# --- JWT Auth ---
# Generate a random 64-byte hex: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_HEX

# --- Default Accounts (Created on first startup) ---
SUPER_EMAIL=super@platform.com
SUPER_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

ADMIN_EMAIL=admin@internal.com
ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
# Required by scripts/seed_admin.py (demo client / tenant name)
ADMIN_CUSTOMER=SecureVU_Demo

MEMBER_EMAIL=member@internal.com
MEMBER_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# --- Detection & Performance Tuning ---
# 1 = General Object Detection
# 2 = Face Detection
# 3 = Fire & Smoke
# 4 = License Plate Detection
# 5 = All Specialized Models
# 6 = Production Mode (YOLO11m + InsightFace)
# 7 = Full Package (YOLO11m + Specialized + InsightFace)
# 8 = Open World (YOLO-World)
# 9 = Production Mode (YOLO11l + InsightFace)
# 10 = Production Mode (YOLO11x + InsightFace)
# 11 = Full Package (YOLO11l + Specialized + InsightFace)
# 12 = Full Package (YOLO11x + Specialized + InsightFace)
MODEL_SELECT=6
# Choose inference runtime: pytorch or tensorrt (requires building .engine file)
MODEL_RUNTIME=pytorch

YOLO_PROCESS_EVERY_N_FRAMES=1
YOLO_MIN_CONF=0.18
YOLO_INPUT_WIDTH=1280
YOLO_INPUT_HEIGHT=1280

# Face recognition (POC: 4 cam, RTX 2080 Ti)
FACE_EVERY_N_FRAMES=3
FACE_RECOGNITION_THRESHOLD=0.25
FACE_MIN_BBOX_HEIGHT=60

# Motion detection (OpenCV background subtraction)
MOTION_ENABLE=1
MOTION_THRESH=0.02
MOTION_ALERT_GAP_SEC=30

# Loitering dwell threshold (seconds)
LINGER_SECONDS=30

# Continuous recording
CONTINUOUS_RECORDING_ENABLE=1
CONTINUOUS_SEGMENT_SECS=300
RECORDINGS_DIR=recordings

# Processing / streaming
PROCESSING_FPS=15
SERVER_CAMERA_FPS=20
GRID_CAMERA_FPS=15

# RTSP cameras (uncomment and set for POC demo)
# RTSP_URL_1=rtsp://user:pass@192.168.1.101:554/cam/realmonitor?channel=1&subtype=0
# RTSP_URL_2=rtsp://user:pass@192.168.1.102:554/cam/realmonitor?channel=1&subtype=0
# RTSP_URL_3=rtsp://user:pass@192.168.1.103:554/cam/realmonitor?channel=1&subtype=0
# RTSP_URL_4=rtsp://user:pass@192.168.1.104:554/cam/realmonitor?channel=1&subtype=0

# --- Video / RTSP Tuning ---
RTSP_USE_PYAV=0
OPENCV_LOG_LEVEL=ERROR
RTSP_RETRY_DELAY_SEC=1.5

# --- Features ---
WORK_TIMER_ENABLE=1
POSTURE_ENABLE=1
EVENT_CLIP_ENABLE=1
ANALYTICS_ALL_CCTV=1
ANALYTICS_CAMERA_IDS=1,2,3,4

# Local dev: use built-in webcam for camera 1 when RTSP fails (Mac/off-LAN)
DEV_WEBCAM_FALLBACK=0

# --- Bounding Box Smoothing Configuration ---
# Choose smoothing mode: fixed or adaptive
BBOX_SMOOTHING_MODE=fixed

# Fixed mode alpha parameter (weight on previous position, 0.0-1.0)
BBOX_FIXED_ALPHA=0.75

# Adaptive mode alphas (lower values mean less smoothing, faster response)
BBOX_ALPHA_HIGH=0.30
BBOX_ALPHA_MEDIUM=0.55
BBOX_ALPHA_LOW=0.80

# Confidence thresholds for adaptive alpha levels
BBOX_CONF_HIGH=0.85
BBOX_CONF_MEDIUM=0.60

# --- MLflow experiment tracking (optional) ---
MLFLOW_ENABLE=1
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_TRAINING=securevu-training
MLFLOW_EXPERIMENT_DEPLOYMENT=securevu-deployment
MLFLOW_MODEL_NAME=securevu-person-detector
